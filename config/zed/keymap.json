[
  {
    "context": "Editor",
    "bindings": {
      "shift-alt-u": "editor::UniqueLinesCaseInsensitive",
      "cmd-shift-r": "editor::ReloadFile",
      "cmd-h": "buffer_search::DeployReplace",
      "cmd-g": "go_to_line::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "command_palette::Toggle",
      "ctrl-`": "workspace::ToggleBottomDock",
      "cmd-`": "workspace::ToggleBottomDock",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "f3": "search::SelectNextMatch",
      "shift-f3": "search::SelectPreviousMatch",
    },
  },
  {
    "context": "BufferSearchBar",
    "bindings": {
      "f3": "search::SelectNextMatch",
      "shift-f3": "search::SelectPreviousMatch",
    },
  },
]
